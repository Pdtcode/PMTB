# Required
DATABASE_URL=postgresql+asyncpg://pmtb:changeme@localhost:5432/pmtb
POSTGRES_PASSWORD=changeme
KALSHI_API_KEY_ID=your-api-key-id
KALSHI_PRIVATE_KEY_PATH=./secrets/kalshi_key.pem

# Optional (defaults shown)
TRADING_MODE=paper
LOG_LEVEL=INFO
EDGE_THRESHOLD=0.04
KELLY_ALPHA=0.25
MAX_DRAWDOWN=0.08
SCAN_INTERVAL_SECONDS=900
STALE_ORDER_TIMEOUT_SECONDS=900
PRICE_OFFSET_CENTS=1
PORTFOLIO_VALUE=10000.0

# Research API keys (optional — VADER-only mode without these)
ANTHROPIC_API_KEY=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
